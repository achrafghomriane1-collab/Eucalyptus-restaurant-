let cart = [];
function changeQty(name, price, delta) {
    let item = cart.find(i => i.name === name);
    if(item) { item.qty += delta; if(item.qty <= 0) cart = cart.filter(i => i.name !== name); }
    else if(delta > 0) cart.push({name, price, qty: 1});
    updateUI();
}
function updateUI() {
    let total = cart.reduce((s, i) => s + (i.price * i.qty), 0);
    document.getElementById('totalPrice').innerText = total;
    cart.forEach(item => {
        let el = document.getElementById(`qty-${item.name.replace(/\s+/g, '-')}`);
        if(el) el.innerText = item.qty;
    });
}
function showCart() {
    let list = cart.map(i => `${i.name} (x${i.qty})`).join('\n');
    alert(list || "السلة فارغة");
}
function sendOrder() {
    alert("تم إرسال طلبك بنجاح! طلبك قيد التحضير، يرجى الانتظار قليلاً في استراحة الكاليتوسة.");
    location.reload();
}
