<!DOCTYPE html>
<html dir="rtl"><head><link rel="stylesheet" href="style.css"></head><body>

<div id="page1" class="overlay" onclick="document.getElementById('page1').style.display='none'; document.getElementById('page2').style.display='block'">
    <h1>استراحة الكاليتوسة</h1><p>اضغط للبدء</p>
</div>

<div id="page2" class="overlay" style="display:none">
    <h2>اختر الطاولة</h2>
    <select id="tNum"><option>الطاولة 1</option><option>الطاولة 2</option></select>
    <button onclick="document.getElementById('page2').style.display='none'; document.getElementById('page3').style.display='block'">استمرار</button>
</div>

<div id="page3" class="overlay" style="display:none">
    <h2>Menu</h2>
    <div class="item"><span>Pizza Margherita (600DA)</span>
        <div class="controls"><button onclick="changeQty('Pizza Margherita', 600, -1)">-</button>
        <span id="qty-Pizza-Margherita">0</span><button onclick="changeQty('Pizza Margherita', 600, 1)">+</button></div>
    </div>
    </div>

<div class="footer" onclick="showCart()">
    الإجمالي: <span id="totalPrice">0</span> DA - <button onclick="sendOrder()">إرسال الطلب</button>
</div>

<script src="script.js"></script>
</body></html>
